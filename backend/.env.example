DATABASE_URL=postgresql://user:password@host:5432/vertualowl
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
ENVIRONMENT=development

# Frontend origins allowed to call the API. Use comma-separated origins.
# 운영: CORS_ORIGINS=https://vertualowl.vercel.app
# 로컬: CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=vertualowl-audio
REDIS_URL=redis://localhost:6379/0

# Observability
SENTRY_DSN=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FEEDBACK_PROVIDER=openai
FEEDBACK_MODEL=gpt-4.1-mini
FEEDBACK_TTS_MODEL=gpt-4o-mini-tts
FEEDBACK_TTS_VOICE=alloy
FEEDBACK_TTS_ENABLED=true
LYRICS_MODEL=gpt-4.1-mini
COMPOSITION_MODEL=gpt-4.1-mini
MODERATION_MODEL=omni-moderation-latest

# Music generation / mastering
MUSIC_GENERATION_PROVIDER=mock
MUBERT_API_KEY=
MASTERING_TARGET_LUFS=-14.0

# Audio validation / copyright checks
VALIDATION_STRICT_MODE=false
ACRCLOUD_HOST=
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
AI_MUSIC_PROBABILITY_THRESHOLD=0.8
STALE_SUBMISSION_TIMEOUT_MINUTES=10
RECOVER_STALE_ON_STARTUP=false

# Rate limits / abuse signals
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
MAX_SUBMISSIONS_PER_DAY=10
ABUSE_USER_SUBMISSIONS_PER_HOUR=5
ABUSE_IP_SUBMISSIONS_PER_HOUR=20
ABUSE_DEVICE_SUBMISSIONS_PER_HOUR=8
ABUSE_AUDIO_SUBMISSIONS_PER_HOUR=3
